// src/pages/uses.astro
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>koels.site — Uses</title>
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='8' fill='%2303030a'/%3E%3Ctext x='16' y='26' text-anchor='middle' font-family='Inter%2C system-ui%2C sans-serif' font-size='26' font-weight='900' fill='url(%23g)'%3EK%3C/text%3E%3Cdefs%3E%3ClinearGradient id='g' x1='0%25' y1='0%25' x2='100%25' y2='100%25'%3E%3Cstop offset='0%25' stop-color='%23a29bfe'/%3E%3Cstop offset='100%25' stop-color='%236c5ce7'/%3E%3C/linearGradient%3E%3C/defs%3E%3C/svg%3E">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:ital,wght@0,300;0,400;0,500;0,700;1,400&display=swap" rel="stylesheet">
<style is:global>
:root {
  --bg:       #03030a;
  --bg2:      #08080f;
  --surface:  #0f0f1a;
  --surface2: #141420;
  --border:   rgba(255,255,255,0.07);
  --border2:  rgba(255,255,255,0.12);
  --text:     #f0eeff;
  --muted:    rgba(240,238,255,0.68);
  --dim:      rgba(240,238,255,0.4);
  --accent:   #6c5ce7;
  --accent2:  #a29bfe;
  --lime:     #00ff88;
  --red:      #ff4757;
  --white:    #ffffff;
  --sans: "Inter", system-ui, sans-serif;
  --mono: "JetBrains Mono", monospace;
  --ease: cubic-bezier(0.16, 1, 0.3, 1);
}

*, *::before, *::after { margin:0; padding:0; box-sizing:border-box }
html { scroll-behavior:smooth; font-size:17px }
body {
  font-family: var(--sans);
  background: var(--bg);
  color: var(--text);
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}
a { color:inherit; text-decoration:none }

body::after {
  content:''; position:fixed; inset:0; pointer-events:none; z-index:9990;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.03'/%3E%3C/svg%3E");
}

/* ── CURTAIN ── */
#curtain {
  position:fixed; inset:0; background:var(--bg); z-index:9997;
  display:flex; align-items:center; justify-content:center;
  transition:opacity 0.8s var(--ease), visibility 0.8s;
}
#curtain.gone { opacity:0; visibility:hidden; pointer-events:none }
.curtain-logo {
  font-family:var(--mono); font-size:0.85rem; letter-spacing:0.25em;
  color:var(--dim); text-transform:uppercase;
  animation:curtain-pulse 1s ease infinite;
}
@keyframes curtain-pulse { 0%,100%{opacity:0.3} 50%{opacity:1} }

/* ── HEADER ── */
header {
  position:fixed; top:0; left:0; right:0; z-index:500;
  height:60px;
  display:flex; align-items:center; justify-content:space-between;
  padding:0 40px;
  border-bottom:1px solid var(--border);
  background:rgba(3,3,10,0.85);
  backdrop-filter:blur(24px) saturate(1.8);
  -webkit-backdrop-filter:blur(24px) saturate(1.8);
}
.logo {
  font-family:var(--mono); font-size:0.7rem; font-weight:700;
  letter-spacing:0.2em; text-transform:uppercase; color:var(--white);
  display:flex; align-items:center; gap:10px;
}
.logo-pulse {
  width:6px; height:6px; border-radius:50%;
  background:var(--lime); box-shadow:0 0 10px var(--lime);
  animation:lg-pulse 2s ease infinite;
}
@keyframes lg-pulse { 0%,100%{box-shadow:0 0 6px var(--lime)} 50%{box-shadow:0 0 20px var(--lime),0 0 40px rgba(0,255,136,0.25)} }

.nav { display:flex; align-items:center; gap:32px }
.nav a {
  font-family:var(--mono); font-size:0.72rem; letter-spacing:0.14em;
  color:var(--muted); text-transform:uppercase; transition:color 0.2s;
}
.nav a:hover { color:var(--white) }

/* ── HERO ── */
.hero {
  padding:160px 56px 80px;
  position:relative;
}
.hero::before {
  content:''; position:absolute; inset:0;
  background-image:
    linear-gradient(var(--border) 1px, transparent 1px),
    linear-gradient(90deg, var(--border) 1px, transparent 1px);
  background-size:64px 64px;
  mask-image:radial-gradient(ellipse 90% 90% at 50% 50%, black 0%, transparent 100%);
  -webkit-mask-image:radial-gradient(ellipse 90% 90% at 50% 50%, black 0%, transparent 100%);
  opacity:0.5; pointer-events:none; z-index:0;
}
.hero-glow {
  position:absolute; top:30%; left:50%;
  transform:translate(-50%,-50%);
  width:700px; height:700px;
  background:radial-gradient(circle, rgba(108,92,231,0.1) 0%, transparent 60%);
  pointer-events:none; z-index:0;
}
.hero-content { position:relative; z-index:2; max-width:720px; }

.eyebrow {
  display:inline-flex; align-items:center; gap:10px;
  font-family:var(--mono); font-size:0.72rem; font-weight:500;
  letter-spacing:0.2em; text-transform:uppercase; color:var(--accent2);
  margin-bottom:32px;
  animation:fade-up 0.9s var(--ease) both;
}
.eyebrow-line { width:28px; height:1px; background:var(--accent) }

h1 {
  font-family:var(--sans);
  font-size:clamp(2.8rem, 5.5vw, 5.5rem);
  font-weight:900; line-height:0.9;
  letter-spacing:-0.04em; color:var(--white);
  animation:fade-up 0.9s 0.07s var(--ease) both;
}
h1 .grad {
  background:linear-gradient(135deg, var(--accent2) 0%, #c084fc 50%, var(--accent2) 100%);
  background-size:200% auto;
  -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
  animation:shimmer 4s linear infinite;
}
@keyframes shimmer { to { background-position:200% center } }

.hero-desc {
  margin-top:28px;
  font-family:var(--mono); font-size:0.85rem; line-height:1.9;
  color:var(--muted); letter-spacing:0.04em; max-width:520px;
  animation:fade-up 0.9s 0.14s var(--ease) both;
}

.hero-back {
  margin-top:44px;
  animation:fade-up 0.9s 0.21s var(--ease) both;
}
.back-link {
  display:inline-flex; align-items:center; gap:8px;
  font-family:var(--mono); font-size:0.68rem; font-weight:700;
  letter-spacing:0.12em; text-transform:uppercase;
  color:var(--accent2); transition:color 0.2s;
}
.back-link:hover { color:var(--white) }
.back-link svg { width:13px; height:13px; fill:currentColor; }

/* ── SECTIONS ── */
.uses-section {
  display:grid; grid-template-columns:240px 1fr;
  border-bottom:1px solid var(--border);
}
.uses-sidebar { padding:64px 40px; border-right:1px solid var(--border) }
.sec-idx { font-family:var(--mono); font-size:0.65rem; letter-spacing:0.2em; color:var(--dim); text-transform:uppercase; margin-bottom:10px }
.sec-title { font-family:var(--sans); font-size:1.1rem; font-weight:600; color:var(--muted); letter-spacing:-0.01em }

.uses-body { padding:64px 64px }
.item-grid { display:flex; flex-direction:column; gap:32px }

.item-card {
  background:var(--surface); border:1px solid var(--border2);
  border-radius:14px; overflow:hidden; position:relative;
  transition:transform 0.25s var(--ease), box-shadow 0.25s var(--ease), border-color 0.25s;
}
.item-card:hover { transform:translateY(-2px); box-shadow:0 8px 32px rgba(0,0,0,0.35); border-color:rgba(108,92,231,0.25); }
.item-stripe { height:2px; background:linear-gradient(90deg, var(--accent), var(--lime)) }
.item-body { padding:28px 32px; display:flex; flex-direction:column; gap:16px }

.item-top { display:flex; align-items:center; justify-content:space-between; gap:16px }
.item-icon {
  width:40px; height:40px; border-radius:10px; flex-shrink:0;
  background:rgba(108,92,231,0.12); border:1px solid rgba(108,92,231,0.2);
  display:flex; align-items:center; justify-content:center;
  font-size:1.1rem;
}
.item-name { font-family:var(--sans); font-size:1.2rem; font-weight:700; color:var(--white); letter-spacing:-0.02em }
.item-tag {
  font-family:var(--mono); font-size:0.52rem; font-weight:700;
  letter-spacing:0.14em; text-transform:uppercase;
  padding:3px 9px; border-radius:4px;
  background:rgba(0,255,136,0.08); border:1px solid rgba(0,255,136,0.2);
  color:var(--lime); white-space:nowrap;
}
.item-desc {
  font-family:var(--mono); font-size:0.78rem; line-height:1.8;
  color:var(--muted); letter-spacing:0.03em;
}
.item-details {
  display:flex; flex-wrap:wrap; gap:6px;
}
.detail-chip {
  font-family:var(--mono); font-size:0.62rem; letter-spacing:0.06em;
  padding:3px 9px; border-radius:4px;
  background:rgba(255,255,255,0.04); border:1px solid var(--border);
  color:rgba(240,238,255,0.5);
}

/* ── FOOTER ── */
footer {
  display:flex; align-items:center; justify-content:space-between; padding:22px 48px;
}
.foot-l, .foot-r { font-family:var(--mono); font-size:0.68rem; letter-spacing:0.12em; color:var(--dim); text-transform:uppercase }
.foot-r { display:flex; gap:18px }

/* ── UTILS ── */
@keyframes fade-up { from{opacity:0;transform:translateY(28px)} to{opacity:1;transform:translateY(0)} }
.reveal { opacity:0; transform:translateY(22px); transition:opacity 0.7s var(--ease), transform 0.7s var(--ease) }
.reveal.visible { opacity:1; transform:translateY(0) }

@media(max-width:860px){
  header { padding:0 20px }
  .nav { display:none }
  .hero { padding:130px 20px 56px }
  .uses-section { grid-template-columns:1fr }
  .uses-sidebar { border-right:none; border-bottom:1px solid var(--border); padding:40px 24px 0 }
  .uses-body { padding:28px 20px 40px }
  .item-body { padding:20px }
  footer { flex-direction:column; gap:10px; text-align:center }
}
</style>
</head>
<body>

<div id="curtain"><div class="curtain-logo">koels.site</div></div>

<!-- HEADER -->
<header>
  <div class="logo"><div class="logo-pulse"></div>Koels.site</div>
  <nav class="nav">
    <a href="/">Home</a>
    <a href="/links">Links</a>
    <a href="/radar">Radar</a>
  </nav>
</header>

<!-- HERO -->
<section class="hero">
  <div class="hero-glow"></div>
  <div class="hero-content">
    <div class="eyebrow"><span class="eyebrow-line"></span>04 / Uses</div>
    <h1><span class="grad">My Setup</span> &<br>Tools.</h1>
    <p class="hero-desc">
      A curated list of the hardware, software, and services I use daily for development, gaming, and hosting.
    </p>
    <div class="hero-back">
      <a href="/" class="back-link">
        <svg viewBox="0 0 24 24"><path d="M15.41 16.59L10.83 12l4.58-4.59L14 6l-6 6 6 6z"/></svg>
        Back to home
      </a>
    </div>
  </div>
</section>

<div style="height:1px;background:linear-gradient(90deg,transparent,var(--border2),transparent);"></div>

<!-- ═══ HARDWARE ═══ -->
<div class="uses-section">
  <div class="uses-sidebar reveal">
    <div class="sec-idx">01 / Hardware</div>
    <div class="sec-title">Computer & Gear</div>
  </div>
  <div class="uses-body reveal" style="transition-delay:.1s">
    <div class="item-grid">

      <div class="item-card">
        <div class="item-stripe"></div>
        <div class="item-body">
          <div class="item-top">
            <div class="item-icon">🖥️</div>
            <div class="item-name">Main PC</div>
            <span class="item-tag">Daily Driver</span>
          </div>
          <div class="item-details">
            <span class="detail-chip">AMD Ryzen 5 5500</span>
            <span class="detail-chip">RTX 3060</span>
            <span class="detail-chip">32GB DDR4 3200MHz</span>
          </div>
        </div>
      </div>

      <div class="item-card">
        <div class="item-stripe"></div>
        <div class="item-body">
          <div class="item-top">
            <div class="item-icon">🖱️</div>
            <div class="item-name">Mouse</div>
          </div>
          <div class="item-desc">Ninjusto Sora V2 — ultralight wireless mouse with precise tracking for work and gaming.</div>
        </div>
      </div>

      <div class="item-card">
        <div class="item-stripe"></div>
        <div class="item-body">
          <div class="item-top">
            <div class="item-icon">⌨️</div>
            <div class="item-name">Keyboard</div>
          </div>
          <div class="item-desc">Logitech G413 TKL SE — clean tenkeyless mechanical with crisp tactile switches.</div>
        </div>
      </div>

      <div class="item-card">
        <div class="item-stripe"></div>
        <div class="item-body">
          <div class="item-top">
            <div class="item-icon">🎧</div>
            <div class="item-name">Headphones</div>
          </div>
          <div class="item-desc">SteelSeries Arctis 7 — wireless over-ear with great battery life, perfect for Discord calls and late-night gaming sessions.</div>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- ═══ SOFTWARE ═══ -->
<div class="uses-section">
  <div class="uses-sidebar reveal">
    <div class="sec-idx">02 / Software</div>
    <div class="sec-title">Dev & Tools</div>
  </div>
  <div class="uses-body reveal" style="transition-delay:.1s">
    <div class="item-grid">

      <div class="item-card">
        <div class="item-stripe"></div>
        <div class="item-body">
          <div class="item-top">
            <div class="item-icon">💻</div>
            <div class="item-name">Code Editor</div>
            <span class="item-tag">Primary</span>
          </div>
          <div class="item-desc">VS Code — lightweight, extensible, and the go-to for web dev and scripting.</div>
          <div class="item-details">
            <span class="detail-chip">Extensions</span>
            <span class="detail-chip">Integrated Terminal</span>
            <span class="detail-chip">Git</span>
          </div>
        </div>
      </div>

      <div class="item-card">
        <div class="item-stripe"></div>
        <div class="item-body">
          <div class="item-top">
            <div class="item-icon">🐚</div>
            <div class="item-name">Terminal</div>
          </div>
          <div class="item-desc">Windows Terminal with a custom PowerShell profile for daily command-line work.</div>
        </div>
      </div>

      <div class="item-card">
        <div class="item-stripe"></div>
        <div class="item-body">
          <div class="item-top">
            <div class="item-icon">🌐</div>
            <div class="item-name">Browser</div>
          </div>
          <div class="item-desc">Chromium-based browser with dark mode and DevTools always ready.</div>
        </div>
      </div>

      <div class="item-card">
        <div class="item-stripe"></div>
        <div class="item-body">
          <div class="item-top">
            <div class="item-icon">🎮</div>
            <div class="item-name">Minecraft Server</div>
            <span class="item-tag">Hosted</span>
          </div>
          <div class="item-desc">Bedrock Edition server running on koels.online — always fresh, always on.</div>
          <div class="item-details">
            <span class="detail-chip">1.21.11</span>
            <span class="detail-chip">Bedrock</span>
            <span class="detail-chip">24/7 Uptime</span>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- ═══ SERVICES ═══ -->
<div class="uses-section">
  <div class="uses-sidebar reveal">
    <div class="sec-idx">03 / Services</div>
    <div class="sec-title">Hosting & Infra</div>
  </div>
  <div class="uses-body reveal" style="transition-delay:.1s">
    <div class="item-grid">

      <div class="item-card">
        <div class="item-stripe"></div>
        <div class="item-body">
          <div class="item-top">
            <div class="item-icon">🚀</div>
            <div class="item-name">GitHub</div>
            <span class="item-tag">Hosting</span>
          </div>
          <div class="item-desc">All sites are hosted on GitHub Pages — free, reliable, and version-controlled.</div>
        </div>
      </div>

      <div class="item-card">
        <div class="item-stripe"></div>
        <div class="item-body">
          <div class="item-top">
            <div class="item-icon">💬</div>
            <div class="item-name">Discord</div>
          </div>
          <div class="item-desc">Primary communication tool — for gaming, dev talk, and everything in between.</div>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- FOOTER -->
<footer>
  <div class="foot-l">© 2026 Koels.site</div>
  <div class="foot-r">
    <a href="/">Home</a>
    <span>·</span>
    <a href="/links">Links</a>
    <span>·</span>
    <a href="/radar">Radar</a>
  </div>
</footer>

<script is:inline>
/* Curtain */
window.addEventListener('load',()=>setTimeout(()=>document.getElementById('curtain').classList.add('gone'),650))

/* Scroll reveal */
const obs=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('visible')}),{threshold:0.1})
document.querySelectorAll('.reveal').forEach(el=>obs.observe(el))
</script>
</body>
</html>
