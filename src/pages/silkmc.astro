---
// src/pages/silkmc.astro â€” SilkMC landing page
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SilkMC â€” Region-Threaded Minecraft Server Software</title>
  <meta name="description" content="A compatibility-focused fork of Folia that keeps the regional multithreaded architecture while narrowing the gap for Paper, Bukkit, and Spigot plugins. Alpha software with known risk." />

  <meta property="og:type"        content="website" />
  <meta property="og:url"         content="https://koels.site/silkmc" />
  <meta property="og:title"       content="SilkMC â€” Region-Threaded Minecraft Server Software" />
  <meta property="og:description" content="An alpha Folia fork focused on preserving multithreaded regions while improving compatibility for Paper, Bukkit, and Spigot plugins." />
  <meta property="og:site_name"   content="SilkMC" />
  <meta property="og:image"       content="https://koels.site/og.png" />
  <meta name="twitter:card"       content="summary_large_image" />
  <meta name="twitter:image"      content="https://koels.site/og.png" />
  <link rel="canonical" href="https://koels.site/silkmc" />

  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='8' fill='%23020810'/%3E%3Ccircle cx='16' cy='16' r='11' fill='none' stroke='%230060b0' stroke-width='1' opacity='0.5'/%3E%3Ccircle cx='16' cy='16' r='7' fill='none' stroke='%2340c8ff' stroke-width='1.2' opacity='0.75'/%3E%3Ccircle cx='16' cy='16' r='3' fill='%2340c8ff'/%3E%3Cpath d='M16 5 L16 11 M16 21 L16 27 M5 16 L11 16 M21 16 L27 16' stroke='%2340c8ff' stroke-width='1.2' stroke-linecap='round' opacity='0.6'/%3E%3C/svg%3E">

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />

  <style>
    @view-transition { navigation: auto; }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:      #020810;
      --bg2:     #040e1e;
      --surface: rgba(2,12,28,0.6);
      --border:  rgba(0,120,200,0.14);
      --border2: rgba(64,200,255,0.22);
      --text:    #c8f0ff;
      --muted:   rgba(200,240,255,0.55);
      --dim:     rgba(200,240,255,0.3);
      --cyan:    #40c8ff;
      --teal:    #00ffcc;
      --ease:    cubic-bezier(0.16,1,0.3,1);
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Inter', sans-serif;
      line-height: 1.6;
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    body::before {
      content: '';
      position: fixed; inset: 0;
      background-image: radial-gradient(circle, rgba(255,255,255,0.018) 1px, transparent 1px);
      background-size: 28px 28px;
      pointer-events: none; z-index: 0;
    }

    body::after {
      content: ''; position: fixed; inset: 0; pointer-events: none; z-index: 9990;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.025'/%3E%3C/svg%3E");
    }

    /* â”€â”€ AURORA â”€â”€ */
    .aurora { position: fixed; inset: 0; pointer-events: none; z-index: 0; overflow: hidden; }
    .ab { position: absolute; border-radius: 50%; filter: blur(120px); }
    .ab1 { width:700px;height:520px;opacity:.24;background:radial-gradient(ellipse,#0050c8 0%,transparent 70%);top:-120px;left:-160px;animation:ab1 40s ease-in-out infinite; }
    .ab2 { width:650px;height:650px;opacity:.16;background:radial-gradient(ellipse,#003080 0%,transparent 70%);top:-80px;right:-140px;animation:ab2 52s ease-in-out infinite; }
    .ab3 { width:520px;height:420px;opacity:.18;background:radial-gradient(ellipse,#00a8b0 0%,transparent 70%);bottom:20%;left:25%;animation:ab3 30s ease-in-out infinite; }
    .ab4 { width:480px;height:480px;opacity:.14;background:radial-gradient(ellipse,#0060b0 0%,transparent 70%);bottom:0;right:8%;animation:ab4 55s ease-in-out infinite; }
    @keyframes ab1{0%,100%{transform:translate(0,0) scale(1)}25%{transform:translate(80px,60px) scale(1.1)}50%{transform:translate(20px,120px) scale(.93)}75%{transform:translate(-40px,40px) scale(1.05)}}
    @keyframes ab2{0%,100%{transform:translate(0,0) scale(1)}30%{transform:translate(-90px,70px) scale(1.08)}60%{transform:translate(-30px,140px) scale(.91)}80%{transform:translate(50px,60px) scale(1.04)}}
    @keyframes ab3{0%,100%{transform:translate(0,0) scale(1)}35%{transform:translate(60px,-80px) scale(1.12)}70%{transform:translate(-50px,-40px) scale(.9)}}
    @keyframes ab4{0%,100%{transform:translate(0,0) scale(1)}40%{transform:translate(-70px,-90px) scale(1.1)}70%{transform:translate(30px,-60px) scale(.94)}}

    nav, main, footer, .stats-strip { position: relative; z-index: 2; }

    /* â”€â”€ NAV â”€â”€ */
    nav {
      position: sticky; top: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 2.5rem; height: 58px;
      background: rgba(2,8,16,0.75);
      backdrop-filter: blur(24px); -webkit-backdrop-filter: blur(24px);
      border-bottom: 1px solid var(--border);
    }

    .logo-dot {
      width: 7px; height: 7px; border-radius: 50%;
      background: var(--teal);
      box-shadow: 0 0 8px var(--teal), 0 0 16px rgba(0,255,204,0.4);
      animation: dot-pulse 2s ease infinite;
      flex-shrink: 0;
    }
    @keyframes dot-pulse{0%,100%{box-shadow:0 0 6px var(--teal)}50%{box-shadow:0 0 20px var(--teal),0 0 40px rgba(0,255,204,0.2)}}

    .nav-right { display: flex; align-items: center; gap: 2rem; }
    .nav-links { display: flex; gap: 1.75rem; list-style: none; }
    .nav-links a { color: var(--muted); text-decoration: none; font-size: 0.82rem; transition: color 0.15s; }
    .nav-links a:hover { color: var(--text); }

    .nav-gh {
      display: inline-flex; align-items: center; gap: 0.4rem;
      padding: 0.38rem 0.9rem; border-radius: 6px;
      border: 1px solid var(--border2); background: var(--surface);
      color: var(--muted); text-decoration: none;
      font-size: 0.8rem; font-weight: 500;
      transition: border-color 0.2s, color 0.2s;
    }
    .nav-gh:hover { border-color: var(--cyan); color: var(--text); }

    .back-link {
      display: flex; align-items: center; gap: 0.5rem;
      font-family: 'JetBrains Mono', monospace; font-size: 0.68rem;
      letter-spacing: 0.12em; text-transform: uppercase;
      color: var(--dim); text-decoration: none;
      transition: color 0.15s;
    }
    .back-link:hover { color: var(--cyan); }

    /* â”€â”€ HERO â”€â”€ */
    .hero {
      position: relative; z-index: 2;
      padding: 7rem 2.5rem 5rem;
      max-width: 1180px; margin: 0 auto;
      animation: fade-up 0.8s var(--ease) both;
    }

    .hero-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4.5rem;
      align-items: center;
    }

    .badge {
      display: inline-flex; align-items: center; gap: 0.5rem;
      padding: 0.28rem 0.9rem; border-radius: 99px;
      border: 1px solid rgba(64,200,255,0.22);
      background: rgba(64,200,255,0.06);
      color: var(--teal); font-size: 0.72rem; font-weight: 500;
      font-family: 'JetBrains Mono', monospace;
      letter-spacing: 0.06em; margin-bottom: 2rem;
      white-space: nowrap;
    }

    .badge-dot {
      width: 5px; height: 5px; border-radius: 50%;
      background: var(--teal); animation: blink 1.4s ease infinite;
    }
    @keyframes blink{0%,100%{opacity:1}50%{opacity:.15}}

    .hero h1 {
      font-size: clamp(2.6rem, 5vw, 4.8rem);
      font-weight: 800; line-height: 1.05; letter-spacing: -0.04em;
      color: #e8f8ff; margin-bottom: 1.4rem;
    }

    .hero h1 .accent {
      background: linear-gradient(135deg, var(--cyan) 0%, var(--teal) 60%, var(--cyan) 100%);
      background-size: 200% auto;
      -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
      animation: shimmer 5s linear infinite;
    }
    @keyframes shimmer { to { background-position: 200% center; } }

    .hero-sub {
      font-size: 1rem; color: var(--muted); line-height: 1.75;
      margin-bottom: 2.2rem; max-width: 460px;
    }

    .hero-actions {
      display: flex; gap: 12px; flex-wrap: wrap;
      margin-bottom: 1.2rem;
    }

    .btn-primary {
      display: inline-flex; align-items: center; gap: 0.5rem;
      padding: 0.75rem 1.6rem; border-radius: 7px;
      background: var(--cyan); color: #010810;
      font-family: 'JetBrains Mono', monospace; font-size: 0.72rem;
      font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
      text-decoration: none; border: 1px solid var(--cyan);
      box-shadow: 0 0 28px rgba(64,200,255,0.25);
      transition: 0.2s var(--ease);
    }
    .btn-primary:hover { background: #2ab0e8; border-color: #2ab0e8; transform: translateY(-1px); }

    .btn-ghost {
      display: inline-flex; align-items: center; gap: 0.5rem;
      padding: 0.75rem 1.6rem; border-radius: 7px;
      background: transparent; color: var(--muted);
      font-family: 'JetBrains Mono', monospace; font-size: 0.72rem;
      font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
      text-decoration: none; border: 1px solid var(--border2);
      transition: 0.2s var(--ease);
    }
    .btn-ghost:hover { color: #e8f8ff; border-color: rgba(64,200,255,0.35); background: rgba(0,120,200,0.08); }

    .hero-version {
      font-family: 'JetBrains Mono', monospace; font-size: 0.65rem;
      letter-spacing: 0.1em; text-transform: uppercase; color: var(--dim);
    }
    .hero-version a { color: var(--cyan); text-decoration: none; }
    .hero-version a:hover { text-decoration: underline; }

    /* â”€â”€ TERMINAL CARD â”€â”€ */
    .hero-right {
      display: flex; flex-direction: column; gap: 10px;
      animation: fade-up 0.9s var(--ease) 0.12s both;
    }

    .terminal-card {
      background: rgba(2,5,12,0.85);
      border: 1px solid rgba(64,200,255,0.13);
      border-radius: 13px;
      overflow: hidden;
      box-shadow:
        0 40px 90px rgba(0,0,0,0.55),
        0 0 0 1px rgba(64,200,255,0.04),
        inset 0 1px 0 rgba(255,255,255,0.025);
    }

    .terminal-bar {
      display: flex; align-items: center;
      padding: 0.65rem 1.1rem;
      background: rgba(255,255,255,0.022);
      border-bottom: 1px solid rgba(64,200,255,0.08);
      gap: 0.5rem;
    }

    .terminal-dots { display: flex; gap: 5px; flex-shrink: 0; }
    .terminal-dots span { width: 9px; height: 9px; border-radius: 50%; }
    .terminal-dots span:nth-child(1) { background: rgba(255,95,86,0.4); }
    .terminal-dots span:nth-child(2) { background: rgba(255,189,46,0.4); }
    .terminal-dots span:nth-child(3) { background: rgba(39,201,63,0.4); }

    .terminal-filename {
      flex: 1; text-align: center;
      font-family: 'JetBrains Mono', monospace; font-size: 0.67rem;
      letter-spacing: 0.1em; color: var(--dim);
    }

    .terminal-body {
      padding: 1.15rem 1.4rem;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.78rem; line-height: 1.9;
    }

    .t-line    { display: block; }
    .t-gap     { display: block; height: 0.55rem; }
    .t-comment { color: rgba(200,240,255,0.22); }
    .t-section { color: var(--cyan); }
    .t-key     { color: var(--text); }
    .t-val     { color: var(--teal); }

    .t-line-del {
      display: block;
      margin: 0 -1.4rem; padding: 0.05rem 1.4rem;
      background: rgba(255,70,70,0.06);
      border-left: 2px solid rgba(255,100,100,0.3);
      color: rgba(255,150,150,0.45);
    }
    .t-line-del .t-val  { color: rgba(255,150,150,0.45); }
    .t-line-del .t-key  { color: rgba(255,150,150,0.45); }

    .t-line-add {
      display: block;
      margin: 0 -1.4rem; padding: 0.05rem 1.4rem;
      background: rgba(0,255,204,0.06);
      border-left: 2px solid var(--teal);
      color: #e8f8ff;
    }
    .t-line-add .t-val { color: var(--teal); }
    .t-ann {
      color: rgba(0,255,204,0.35); font-size: 0.67rem;
      margin-left: 0.75rem;
    }

    /* mini metrics grid below terminal */
    .hero-metrics {
      display: grid; grid-template-columns: 1fr 1fr; gap: 8px;
    }

    .hero-metric {
      background: rgba(2,12,28,0.55);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 0.85rem 1rem;
      display: flex; flex-direction: column; gap: 0.2rem;
      transition: border-color 0.2s;
    }
    .hero-metric:hover { border-color: var(--border2); }

    .metric-val {
      font-family: 'JetBrains Mono', monospace;
      font-size: 1.05rem; font-weight: 700; letter-spacing: -0.02em;
      color: #e8f8ff; line-height: 1;
    }
    .metric-val.c { color: var(--cyan); }
    .metric-val.g { color: var(--teal); }

    .metric-label {
      font-family: 'JetBrains Mono', monospace; font-size: 0.59rem;
      letter-spacing: 0.12em; text-transform: uppercase; color: var(--dim);
    }

    /* â”€â”€ STATS STRIP â”€â”€ */
    .stats-strip {
      display: flex; justify-content: center;
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }

    .stat {
      flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center;
      gap: 0.25rem; padding: 1.8rem 1rem;
      border-right: 1px solid var(--border);
    }
    .stat:last-child { border-right: none; }

    .stat-value {
      font-size: 1.9rem; font-weight: 900; letter-spacing: -0.04em;
      line-height: 1; color: #e8f8ff;
    }
    .stat-value.c { color: var(--cyan); text-shadow: 0 0 32px rgba(64,200,255,0.3); }
    .stat-value.g { color: var(--teal); text-shadow: 0 0 28px rgba(0,255,204,0.25); }

    .stat-label {
      font-family: 'JetBrains Mono', monospace; font-size: 0.63rem;
      letter-spacing: 0.12em; text-transform: uppercase;
      color: var(--dim); text-align: center;
    }

    .stat-note {
      font-family: 'JetBrains Mono', monospace; font-size: 0.58rem;
      letter-spacing: 0.06em; color: rgba(200,240,255,0.18);
      margin-top: 0.1rem;
    }

    /* â”€â”€ SECTION â”€â”€ */
    .section {
      padding: 6rem 1.5rem; max-width: 1080px; margin: 0 auto;
    }

    .section-tag {
      display: block;
      font-family: 'JetBrains Mono', monospace; font-size: 0.68rem;
      letter-spacing: 0.2em; text-transform: uppercase; color: var(--cyan);
      margin-bottom: 1rem;
    }

    .section h2 {
      font-size: clamp(1.8rem, 3.5vw, 2.8rem);
      font-weight: 800; letter-spacing: -0.03em;
      color: #e8f8ff; margin-bottom: 3rem; line-height: 1.2;
    }

    /* â”€â”€ BENTO GRID â”€â”€ */
    .bento {
      display: grid; grid-template-columns: repeat(6, 1fr); gap: 12px;
    }

    .card {
      background: rgba(2,12,28,0.55); border: 1px solid var(--border);
      border-radius: 14px; padding: 1.8rem;
      backdrop-filter: blur(16px);
      display: flex; flex-direction: column; gap: 0.75rem;
      position: relative; overflow: hidden;
      transition: border-color 0.25s, transform 0.25s var(--ease), box-shadow 0.25s;
    }
    .card::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
      background: linear-gradient(90deg, transparent, var(--cyan), transparent);
      opacity: 0; transition: opacity 0.3s;
    }
    .card:hover { border-color: var(--border2); transform: translateY(-3px); box-shadow: 0 16px 48px rgba(0,0,0,0.4); }
    .card:hover::before { opacity: 1; }

    .c2 { grid-column: span 2; }
    .c3 { grid-column: span 3; }

    .card-icon  { font-size: 1.4rem; line-height: 1; }

    .card-title {
      font-size: 1rem; font-weight: 700; letter-spacing: -0.01em; color: #e8f8ff;
    }

    .card-body { font-size: 0.875rem; color: var(--muted); line-height: 1.65; flex: 1; }

    .card-chip {
      display: inline-flex; align-self: flex-start;
      font-family: 'JetBrains Mono', monospace; font-size: 0.6rem;
      letter-spacing: 0.12em; text-transform: uppercase;
      padding: 3px 9px; border-radius: 99px;
      color: var(--teal); border: 1px solid rgba(0,255,204,0.3);
      background: rgba(0,255,204,0.06);
    }
    .card-chip.blue {
      color: var(--cyan); border-color: rgba(64,200,255,0.3); background: rgba(64,200,255,0.06);
    }

    /* featured layout for top two cards */
    .card-feat-inner {
      display: flex; justify-content: space-between; align-items: flex-start; gap: 1.2rem;
    }
    .card-feat-left { display: flex; flex-direction: column; gap: 0.75rem; flex: 1; }

    .card-metric-box {
      flex-shrink: 0;
      display: flex; flex-direction: column; align-items: center; gap: 0.15rem;
      padding: 0.85rem 1.1rem;
      background: rgba(64,200,255,0.05);
      border: 1px solid rgba(64,200,255,0.1);
      border-radius: 10px;
      min-width: 84px;
    }
    .card-metric-box.g {
      background: rgba(0,255,204,0.04);
      border-color: rgba(0,255,204,0.1);
    }

    .card-metric-num {
      font-family: 'JetBrains Mono', monospace;
      font-size: 1.55rem; font-weight: 900; letter-spacing: -0.04em;
      line-height: 1; color: var(--cyan);
      text-shadow: 0 0 24px rgba(64,200,255,0.35);
    }
    .card-metric-num.g {
      color: var(--teal);
      text-shadow: 0 0 24px rgba(0,255,204,0.3);
    }

    .card-metric-sub {
      font-family: 'JetBrains Mono', monospace; font-size: 0.56rem;
      letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--dim); text-align: center;
    }

    /* pack limit visual bars */
    .pack-bars { display: flex; flex-direction: column; gap: 6px; margin-top: 0.5rem; }
    .pack-bar-row { display: flex; align-items: center; gap: 8px; }
    .pack-bar-label {
      font-family: 'JetBrains Mono', monospace; font-size: 0.57rem;
      letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--dim); flex-shrink: 0; width: 48px;
    }
    .pack-bar-track { flex: 1; height: 4px; background: rgba(0,120,200,0.1); border-radius: 99px; overflow: hidden; }
    .pack-bar-fill   { height: 100%; border-radius: 99px; }
    .pack-bar-fill.vanilla { width: 6.25%; background: rgba(200,240,255,0.18); }
    .pack-bar-fill.silk { width: 100%; background: linear-gradient(90deg, var(--cyan), var(--teal)); }
    .pack-bar-val {
      font-family: 'JetBrains Mono', monospace; font-size: 0.62rem;
      color: var(--muted); flex-shrink: 0; min-width: 32px; text-align: right;
    }

    /* â”€â”€ SETUP STEPS â”€â”€ */
    .steps { display: flex; flex-direction: column; gap: 0; margin-top: 3rem; }

    .step {
      display: flex; align-items: flex-start; gap: 1.5rem;
      padding: 1.5rem 0;
      border-bottom: 1px solid var(--border);
    }
    .step:first-child { border-top: 1px solid var(--border); }

    .step-num {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.65rem; letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--cyan); flex-shrink: 0; padding-top: 0.15rem; min-width: 32px;
    }

    .step-content { flex: 1; }

    .step-title { font-size: 0.95rem; font-weight: 600; color: #e8f8ff; margin-bottom: 0.35rem; }
    .step-desc  { font-size: 0.85rem; color: var(--muted); line-height: 1.6; }

    .code-block {
      display: block; margin-top: 0.75rem;
      padding: 0.85rem 1.1rem; border-radius: 8px;
      background: rgba(0,0,0,0.35); border: 1px solid rgba(64,200,255,0.1);
      font-family: 'JetBrains Mono', monospace; font-size: 0.78rem;
      color: var(--teal); line-height: 1.55; white-space: pre; overflow-x: auto;
    }

    /* â”€â”€ CONFIG PREVIEW â”€â”€ */
    .config-preview {
      margin-top: 3rem; padding: 1.5rem;
      background: rgba(0,0,0,0.35); border: 1px solid rgba(64,200,255,0.12);
      border-radius: 12px; overflow-x: auto;
    }

    .config-header {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 1rem;
    }

    .config-filename {
      font-family: 'JetBrains Mono', monospace; font-size: 0.7rem;
      letter-spacing: 0.1em; color: var(--dim);
    }

    .config-copy {
      font-family: 'JetBrains Mono', monospace; font-size: 0.62rem;
      letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--cyan); background: none; border: none; cursor: pointer;
      transition: color 0.2s; padding: 0;
    }
    .config-copy:hover { color: var(--teal); }

    .config-code {
      font-family: 'JetBrains Mono', monospace; font-size: 0.78rem;
      color: var(--text); line-height: 1.7; white-space: pre;
    }

    .cfg-comment { color: rgba(200,240,255,0.3); }
    .cfg-section { color: var(--cyan); }
    .cfg-key     { color: var(--text); }
    .cfg-val     { color: var(--teal); }

    /* â”€â”€ COMPAT GRID â”€â”€ */
    .compat-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(200px,1fr));
      gap: 10px; margin-top: 2.5rem;
    }

    .compat-card {
      display: flex; align-items: center; gap: 0.85rem;
      padding: 0.9rem 1.1rem; border-radius: 10px;
      background: rgba(2,12,28,0.5); border: 1px solid var(--border);
      transition: border-color 0.2s;
    }
    .compat-card:hover { border-color: var(--border2); }

    .compat-icon { font-size: 1.15rem; flex-shrink: 0; }
    .compat-info { flex: 1; }
    .compat-name   { font-size: 0.85rem; font-weight: 600; color: #e8f8ff; }
    .compat-status { font-family: 'JetBrains Mono', monospace; font-size: 0.6rem; letter-spacing: 0.1em; text-transform: uppercase; }
    .compat-status.ok       { color: var(--teal); }
    .compat-status.improved { color: var(--cyan); }

    /* â”€â”€ FOOTER â”€â”€ */
    footer {
      display: flex; flex-direction: column; align-items: center; gap: 1rem;
      padding: 2.5rem 1.5rem; text-align: center;
      border-top: 1px solid var(--border);
      position: relative; z-index: 2;
    }

    .footer-logo {
      display: flex; align-items: center; gap: 0.5rem;
      font-family: 'JetBrains Mono', monospace; font-weight: 700;
      font-size: 0.72rem; letter-spacing: 0.15em; text-transform: uppercase;
      color: var(--muted); text-decoration: none;
    }
    .footer-logo .logo-dot { width: 6px; height: 6px; box-shadow: 0 0 5px var(--teal); }

    .footer-links { display: flex; gap: 1.75rem; }
    .footer-links a { font-size: 0.78rem; color: var(--dim); text-decoration: none; transition: color 0.15s; }
    .footer-links a:hover { color: var(--text); }

    .footer-copy { font-size: 0.72rem; color: var(--dim); }

    /* â”€â”€ UTILS â”€â”€ */
    @keyframes fade-up { from{opacity:0;transform:translateY(24px)} to{opacity:1;transform:translateY(0)} }
    .reveal { opacity: 0; transform: translateY(20px); transition: opacity 0.7s var(--ease), transform 0.7s var(--ease); }
    .reveal.visible { opacity: 1; transform: translateY(0); }

    .toast {
      position: fixed; bottom: 32px; left: 50%; transform: translateX(-50%) translateY(16px);
      background: rgba(2,12,28,0.9); backdrop-filter: blur(16px);
      border: 1px solid var(--border2);
      color: var(--teal); font-family: 'JetBrains Mono', monospace; font-size: 0.65rem;
      letter-spacing: 0.12em; text-transform: uppercase;
      padding: 11px 22px; border-radius: 6px;
      opacity: 0; transition: opacity 0.3s, transform 0.3s;
      z-index: 9999; pointer-events: none;
    }
    .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

    /* â”€â”€ RESPONSIVE â”€â”€ */
    @media(max-width: 960px) {
      .hero-inner { grid-template-columns: 1fr; gap: 3rem; }
      .hero-sub   { max-width: 100%; }
    }

    @media(max-width: 860px) {
      .c2, .c3 { grid-column: span 6; }
      .card-feat-inner { flex-direction: column; }
    }

    @media(max-width: 700px) {
      nav { padding: 0 1.25rem; }
      .nav-links { display: none; }
      .hero { padding: 5rem 1.25rem 4rem; }
      .stats-strip { flex-wrap: wrap; }
      .stat { min-width: 50%; border-right: none; border-bottom: 1px solid var(--border); }
      .section { padding: 4rem 1.25rem; }
      .footer-links { gap: 1.25rem; }
    }
  </style>
</head>
