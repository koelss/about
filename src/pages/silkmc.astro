  <script is:inline>
    (async () => {
      try {
        const res = await fetch('https://api.github.com/repos/tame-gg/SilkMC/releases/latest');
        if (!res.ok) return;
        const release = await res.json();
        const tag = release.tag_name || 'v0.1.1-alpha';
        const label = document.getElementById('release-name');
        if (label) label.textContent = tag;

        const paperclip = (release.assets || []).find(asset => /paperclip.*\.jar$/i.test(asset.name));
        const button = document.getElementById('download-button');
        if (button && paperclip) {
          button.href = paperclip.browser_download_url;
          button.setAttribute('download', paperclip.name);
        }
      } catch (_) {}
    })();
  </script>
