---
const version = 'v1.0.0';
const releaseDate = 'May 2025';
---

<section id="download" class="relative py-32 px-6 overflow-hidden">

  <!-- Glow bg -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[700px] h-[400px] rounded-full"
         style="background:radial-gradient(ellipse,rgba(255,70,85,0.09),transparent 65%);filter:blur(60px)"></div>
    <div class="absolute inset-x-0 top-0 h-px"
         style="background:linear-gradient(90deg,transparent,rgba(255,255,255,0.06),transparent)"></div>
  </div>

  <div class="max-w-3xl mx-auto text-center">

    <!-- Label -->
    <div data-reveal>
      <span class="section-label mb-4 inline-flex justify-center">Download</span>

      <h2 class="text-4xl md:text-5xl font-black tracking-tighter text-white mb-4 leading-tight">
        Ready to level up<br/>
        <span class="text-gradient-red">your game sense?</span>
      </h2>

      <p class="text-base leading-relaxed mb-10 max-w-md mx-auto" style="color:rgba(240,240,245,0.4)">
        Free. Private. No account. No subscription.
        Just install and open — Vanta does the rest.
      </p>
    </div>

    <!-- Download card -->
    <div
      class="relative rounded-2xl p-8 mb-8 text-left"
      style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08)"
      data-reveal
      data-reveal-d="1"
    >
      <!-- Top red glow line -->
      <div class="absolute inset-x-0 top-0 h-px rounded-t-2xl"
           style="background:linear-gradient(90deg,transparent,rgba(255,70,85,0.4),transparent)"></div>

      <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">

        <!-- Version info -->
        <div class="flex items-center gap-4">
          <div class="w-14 h-14 rounded-xl flex items-center justify-center shrink-0"
               style="background:rgba(255,70,85,0.1);border:1px solid rgba(255,70,85,0.2)">
            <!-- Windows logo -->
            <svg width="24" height="24" viewBox="0 0 24 24" fill="#ff6070">
              <path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801"/>
            </svg>
          </div>
          <div>
            <div class="text-white font-bold text-base mb-0.5">Vanta for Windows</div>
            <div class="flex items-center gap-2 flex-wrap">
              <span class="text-xs font-mono px-2 py-0.5 rounded-full" style="background:rgba(255,70,85,0.1);color:#ff6070;border:1px solid rgba(255,70,85,0.2)">{version}</span>
              <span class="text-xs font-mono" style="color:rgba(240,240,245,0.3)">{releaseDate}</span>
              <span class="text-xs font-mono" style="color:rgba(240,240,245,0.3)">·</span>
              <span class="text-xs font-mono" style="color:rgba(240,240,245,0.3)">Windows 10 / 11 · x64</span>
            </div>
            <div class="mt-1.5 flex items-center gap-3 flex-wrap">
              <span class="text-[0.62rem] font-mono" style="color:rgba(240,240,245,0.28)">Installer .exe · ~55 MB</span>
            </div>
          </div>
        </div>

        <!-- Download button -->
        <a
          href="https://github.com/koelss/vanta/releases/latest"
          class="group flex items-center gap-3 px-6 py-3 rounded-lg font-semibold text-sm whitespace-nowrap transition-all duration-200 hover:brightness-110 active:scale-[0.98] shrink-0"
          style="background:#ff4655;color:#fff;box-shadow:0 0 32px rgba(255,70,85,0.35)"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
            <path d="M12 5v14M5 12l7 7 7-7"/>
          </svg>
          Download Free
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
               class="opacity-60 group-hover:opacity-100 transition-opacity">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
            <polyline points="15 3 21 3 21 9"/>
            <line x1="10" y1="14" x2="21" y2="3"/>
          </svg>
        </a>
      </div>

      <!-- Checklist -->
      <div class="mt-6 pt-5 grid grid-cols-2 sm:grid-cols-4 gap-3 border-t" style="border-color:rgba(255,255,255,0.06)">
        {[
          'No sign-up required',
          'No telemetry or ads',
          'Open source (MIT)',
          'Automatic updates',
        ].map(item => (
          <div class="flex items-center gap-2">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#34c759" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            <span class="text-[0.65rem] font-mono" style="color:rgba(240,240,245,0.4)">{item}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Secondary: View on GitHub -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4" data-reveal data-reveal-d="2">
      <a
        href="https://github.com/koelss/vanta"
        class="flex items-center gap-2.5 px-5 py-2.5 rounded-lg font-medium text-sm transition-all duration-200 hover:bg-white/10"
        style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);color:rgba(240,240,245,0.6)"
        target="_blank"
        rel="noopener noreferrer"
      >
        <!-- GitHub logo -->
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
        </svg>
        View on GitHub
      </a>

      <span class="text-xs font-mono" style="color:rgba(240,240,245,0.2)">or</span>

      <a
        href="https://github.com/koelss/vanta/releases"
        class="flex items-center gap-2 text-sm transition-colors hover:text-white/60"
        style="color:rgba(240,240,245,0.3)"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
        </svg>
        All releases &amp; changelog
      </a>
    </div>

    <!-- Riot disclaimer -->
    <p class="mt-12 text-[0.6rem] font-mono leading-relaxed mx-auto max-w-lg" style="color:rgba(240,240,245,0.18)">
      Vanta is an independent project and is not affiliated with, endorsed by, or sponsored by Riot Games.
      VALORANT and all related marks are trademarks of Riot Games, Inc.
    </p>
  </div>
</section>
